# Cashfree Payment Gateway
# Copy this file to .env and fill in your actual keys
# .env is gitignored - never commit real keys

CASHFREE_ENV=TEST

# Test credentials (from Cashfree sandbox dashboard)
CASHFREE_APP_ID_TEST=YOUR_TEST_APP_ID
CASHFREE_SECRET_KEY_TEST=YOUR_TEST_SECRET_KEY

# Production credentials (fill after KYC approval)
CASHFREE_APP_ID_PROD=YOUR_PROD_APP_ID
CASHFREE_SECRET_KEY_PROD=YOUR_PROD_SECRET_KEY

# Optional: override default region
# FUNCTIONS_REGION=us-central1
