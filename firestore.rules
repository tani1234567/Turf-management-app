rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Role helpers ──────────────────────────────────────────────────────────
    function isAdminRole() {
      return request.auth.token.role in ['admin', 'super_admin'];
    }

    function isManagerOrOwner() {
      return request.auth.token.role in ['manager', 'owner', 'admin', 'super_admin'];
    }

    function userCompanyId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId;
    }

    // ── Default: authenticated users can read/write everything not explicitly covered
    // TODO: tighten per-collection as the app matures
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // ── Coupons ───────────────────────────────────────────────────────────────
    match /coupons/{couponId} {
      // Any authenticated user can read coupons (needed to validate codes)
      allow read: if request.auth != null;

      // Only admins can create new coupons or delete them
      allow create, delete: if request.auth != null && isAdminRole();

      // Admins can update any field.
      // Managers/owners can ONLY update companyStatus (their toggle) on their own company's coupon.
      allow update: if request.auth != null && (
        isAdminRole()
        ||
        (
          isManagerOrOwner()
          && resource.data.companyId == userCompanyId()
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['companyStatus', 'updatedAt'])
        )
      );
    }

    // ── Coupon Usages ─────────────────────────────────────────────────────────
    match /couponUsages/{usageId} {
      // User can read their own usage records; admins and company managers can read all
      allow read: if request.auth != null && (
        isAdminRole()
        || resource.data.userId == request.auth.uid
        || (isManagerOrOwner() && resource.data.companyId == userCompanyId())
      );

      // Users may only create a usage record that belongs to themselves.
      // The booking transaction creates these under the user's auth token.
      // Update and delete are blocked — usage records are immutable.
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.couponId is string
        && request.resource.data.bookingId is string;

      allow update, delete: if false;
    }

    // ── Support Tickets ──────────────────────────────────────────────────────
    match /support_tickets/{ticketId} {
      // Users can only create their own tickets (source must be "mobile")
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.source == 'mobile';

      // Users can read their own tickets; admins can read all
      allow read: if request.auth != null
        && (resource.data.userId == request.auth.uid
            || request.auth.token.role in ['super_admin', 'support_admin', 'finance_admin', 'read_only']);

      // Only admins can update/delete ticket docs
      allow update, delete: if request.auth != null
        && request.auth.token.role in ['super_admin', 'support_admin'];

      // Message sub-collection
      match /messages/{messageId} {
        // Users can add their own user-type messages; admins can add admin-type messages
        allow create: if request.auth != null
          && (
            (request.resource.data.senderType == 'user'
              && request.resource.data.senderId == request.auth.uid)
            || request.auth.token.role in ['super_admin', 'support_admin']
          );

        // Users can read messages in their own ticket; admins can read all
        allow read: if request.auth != null
          && (
            get(/databases/$(database)/documents/support_tickets/$(ticketId)).data.userId == request.auth.uid
            || request.auth.token.role in ['super_admin', 'support_admin', 'finance_admin', 'read_only']
          );
      }
    }

    // ── Disputes ─────────────────────────────────────────────────────────────
    match /disputes/{disputeId} {
      // Users can only create their own disputes (source must be "mobile")
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.source == 'mobile';

      // Users can read their own disputes; admins can read all
      allow read: if request.auth != null
        && (resource.data.userId == request.auth.uid
            || request.auth.token.role in ['super_admin', 'support_admin', 'finance_admin', 'read_only']);

      // Only admins can update/delete disputes
      allow update, delete: if request.auth != null
        && request.auth.token.role in ['super_admin', 'support_admin', 'finance_admin'];
    }

    // ── Refunds ──────────────────────────────────────────────────────────────
    match /refunds/{refundId} {
      // Users can only read their own refund records
      allow read: if request.auth != null
        && (resource.data.userId == request.auth.uid
            || request.auth.token.role in ['super_admin', 'finance_admin', 'read_only']);

      // Refund writes come from Cloud Functions (Admin SDK bypasses rules) or finance admins
      allow write: if request.auth != null
        && request.auth.token.role in ['super_admin', 'finance_admin'];
    }
  }
}
